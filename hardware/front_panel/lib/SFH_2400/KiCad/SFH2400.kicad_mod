(module "SFH2400" (layer F.Cu)
  (descr "3-SMD, Gull Wing")
  (tags "Photodiode")
  (attr smd)
  (fp_text reference D** (at 0.000 -0) (layer F.SilkS)
    (effects (font (size 1.27 1.27) (thickness 0.254)))
  )
  (fp_text user %R (at 0.000 -0) (layer F.Fab)
    (effects (font (size 1.27 1.27) (thickness 0.254)))
  )
  (fp_text value "SFH2400" (at 0.000 -0) (layer F.SilkS) hide
    (effects (font (size 1.27 1.27) (thickness 0.254)))
  )
  (fp_line (start -1.3 -1) (end 1.3 -1) (layer F.Fab) (width 0.1))
  (fp_line (start 1.3 -1) (end 1.3 1) (layer F.Fab) (width 0.1))
  (fp_line (start 1.3 1) (end -1.3 1) (layer F.Fab) (width 0.1))
  (fp_line (start -1.3 1) (end -1.3 -1) (layer F.Fab) (width 0.1))
  (fp_line (start -4 -2.15) (end 4 -2.15) (layer F.CrtYd) (width 0.1))
  (fp_line (start 4 -2.15) (end 4 2.15) (layer F.CrtYd) (width 0.1))
  (fp_line (start 4 2.15) (end -4 2.15) (layer F.CrtYd) (width 0.1))
  (fp_line (start -4 2.15) (end -4 -2.15) (layer F.CrtYd) (width 0.1))
  (fp_line (start 0.8 -1) (end -1.3 -1) (layer F.SilkS) (width 0.2))
  (fp_line (start -1.3 1) (end 0.8 1) (layer F.SilkS) (width 0.2))
  (fp_line (start -3.6 -0) (end -3.6 -0) (layer F.SilkS) (width 0.1))
  (fp_line (start -3.5 -0) (end -3.5 -0) (layer F.SilkS) (width 0.1))
  (fp_arc (start -3.55 -0) (end -3.600 -0) (angle -180) (layer F.SilkS) (width 0.1))
  (fp_arc (start -3.55 -0) (end -3.500 -0) (angle -180) (layer F.SilkS) (width 0.1))
  (pad 1 smd rect (at -2.100 -0 90) (size 1.300 1.800) (layers F.Cu F.Paste F.Mask))
  (pad 2 smd rect (at 2.100 -0.65 90) (size 1.000 1.800) (layers F.Cu F.Paste F.Mask))
  (pad 3 smd rect (at 2.100 0.65 90) (size 1.000 1.800) (layers F.Cu F.Paste F.Mask))
  (model SFH_2400.stp
    (at (xyz 0 0 0))
    (scale (xyz 1 1 1))
    (rotate (xyz 0 0 0))
  )
)

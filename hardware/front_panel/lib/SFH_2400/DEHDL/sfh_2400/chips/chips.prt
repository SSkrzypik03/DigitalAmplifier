FILE_TYPE=LIBRARY_PARTS;
PRIMITIVE 'SFH_2400','SFH_2400_Other';
  PIN
    'CATHODE':
      PIN_NUMBER='(1)';
      NO_LOAD_CHECK=BOTH;
      NO_IO_CHECK=BOTH;
      ALLOW_CONNECT=TRUE;
      PINUSE='UNSPEC';
    'N.C.':
      PIN_NUMBER='(2)';
      NO_LOAD_CHECK=BOTH;
      NO_IO_CHECK=BOTH;
      ALLOW_CONNECT=TRUE;
      PINUSE='NC';
    'ANODE':
      PIN_NUMBER='(3)';
      NO_LOAD_CHECK=BOTH;
      NO_IO_CHECK=BOTH;
      ALLOW_CONNECT=TRUE;
      PINUSE='UNSPEC';
  END_PIN;
  BODY
    PART_NAME='SFH_2400';
    PHYS_DES_PREFIX='D';
    NO_LOAD_CHECK='TRUE';
    PIN_COUNT='3';
    BODY_NAME='SFH_2400';
    JEDEC_TYPE='SFH2400';
  END_BODY;
END_PRIMITIVE;
END.

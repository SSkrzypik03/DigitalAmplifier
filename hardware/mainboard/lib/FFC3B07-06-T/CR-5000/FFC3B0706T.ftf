        (throughMode NONTHROUGH)
        (panelUse NO)
        (padSet (footLayer Top)
          (connect (pad r280_250))
          (noconnect (pad r280_250))
        )
        (padSet (footLayer Resist-Top)
          (connect (pad r280_250))
          (noconnect (pad r280_250))
        )
        (padSet (footLayer MetalMask-Top)
          (connect (pad r280_250))
          (noconnect (pad r280_250))
        )
      )
    ); End of padstacks
    (footprints
      (footprint "FFC3B0706T"
        (polarity YES)
        (panelUse NO)
        (heelprint
          (layout

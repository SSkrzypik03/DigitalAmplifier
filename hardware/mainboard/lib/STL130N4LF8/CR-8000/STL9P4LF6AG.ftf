                  (line
                    (vertex
                      (pt -157500 -150000
                        (width 10000)
                      )
                      (pt -157500 150000
                        (width 10000)
                      )
                    )
                  )
                )
              )
            )
            (layer (footLayer CompArea-Top)
              (area
                (geometry
                  (surface
                    (outlineWidth 0)
                    (fillWidth 0)
                    (fillAngle 0.000000)
                    (vertex
                    (pt 277500 290000)
                    (pt 277500 -290000)
                    (pt -277500 -290000)
                    (pt -277500 290000)
                    )
                  )
                )
              )
            )
            (layer (footLayer Silk-Top)
              (line
                (geometry
                  (line
                    (vertex
                      (pt -97500 -230000
                        (width 20000)
                      )
                      (pt -97500 -230000
                        (width 20000)
                      )
                    )
                  )
                )
              )
            )
            (layer (footLayer Silk-Top)
              (line
                (geometry
                  (line
                    (vertex
                      (arc CCW
                        (r 5000)
                        (begin
                          (pt -97500 -230000
                            (width 20000)
                          )
                        )
                        (center 0 -1073741824)
                        (end
                          (pt -97500 -240000
                            (width 20000)
                          )
                        )
                      )
                    )
                  )
                )
              )
            )
            (layer (footLayer Silk-Top)
              (line
                (geometry
                  (line
                    (vertex
                      (arc CCW
                        (r 5000)
                        (begin
                          (pt -97500 -240000
                            (width 20000)
                          )
                        )
                        (center 0 1073741824)
                        (end
                          (pt -97500 -230000
                            (width 20000)
                          )
                        )
                      )
                    )
                  )
                )
              )
            )
            (layer (footLayer Silk-Top)
              (line
                (geometry
                  (line
                    (vertex
                      (arc CCW
                        (r 5000)
                        (begin
                          (pt -97500 -230000
                            (width 20000)
                          )
                        )
                        (center 0 -1073741824)
                        (end
                          (pt -97500 -240000
                            (width 20000)
                          )
                        )
                      )
                    )
                  )
                )
              )
            )
           ); End of layout
         ); End of heelprint
         (toeprint
          (pin 1
            (pt -97500 -152500)
            (layout
              (layer (FPADSTACK)
                (fpadstack
                  (pt -97500 -152500)
                  (angle 0)
                  (padstackGroup default (padstack r75_40))
                )
              )
            )
          )
          (pin 2
            (pt -32500 -152500)
            (layout
              (layer (FPADSTACK)
                (fpadstack
                  (pt -32500 -152500)
                  (angle 0)
                  (padstackGroup default (padstack r75_40))
                )
              )
            )
          )
          (pin 3
            (pt 32500 -152500)
            (layout
              (layer (FPADSTACK)
                (fpadstack
                  (pt 32500 -152500)
                  (angle 0)
                  (padstackGroup default (padstack r75_40))
                )
              )
            )
          )
          (pin 4
            (pt 97500 -152500)
            (layout
              (layer (FPADSTACK)
                (fpadstack
                  (pt 97500 -152500)
                  (angle 0)
                  (padstackGroup default (padstack r75_40))
                )
              )
            )
          )
          (pin 5
            (pt 0 70000)
            (layout
              (layer (FPADSTACK)
                (fpadstack
                  (pt 0 70000)
                  (angle 90)
                  (padstackGroup default (padstack r245_240))
                )
              )
            )
          )
          (pin 6
            (pt 149000 0)
            (layout
              (layer (FPADSTACK)
                (fpadstack
                  (pt 149000 0)
                  (angle 90)
                  (padstackGroup default (padstack r53_40))
                )
              )
            )

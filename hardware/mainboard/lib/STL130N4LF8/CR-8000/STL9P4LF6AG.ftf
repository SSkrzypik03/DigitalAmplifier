                (fpadstack
                  (pt -149000 0)
                  (angle 90)
                  (padstackGroup default (padstack r53_40))
                )
              )
            )
          )
        ); End of toeprint
        (propertyS accurateShape STL130N4LF8.stp)
      ); End of footprint
    ); End of footprints
  );  End of footprintContainer
); End of ftf

